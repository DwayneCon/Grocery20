{
  "name": "grocery-planner",
  "version": "1.0.0",
  "description": "AI-Powered Smart Meal Planner - Full Stack Application",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "start": "cd server && npm start",
    "db:setup": "mysql -u root -p < scripts/schema.sql",
    "db:seed": "mysql -u root -p grocery_planner < scripts/seed.sql",
    "deploy": "bash scripts/deploy.sh",
    "clean": "rm -rf client/dist client/node_modules server/dist server/node_modules node_modules",
    "type-check": "cd client && npm run type-check && cd ../server && tsc --noEmit",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report"
  },
  "keywords": [
    "meal-planning",
    "ai",
    "grocery",
    "react",
    "nodejs",
    "typescript"
  ],
  "author": "Dwayne Concepcion",
  "license": "ISC",
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1"
  }
}
